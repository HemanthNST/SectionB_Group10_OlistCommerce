      <aliases enabled='yes' />
      <column caption='On-Time Rate' datatype='real' name='[Calculation_0309987192565760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([is_on_time])) / COUNT([order_id])' />
      </column>
      <column caption='Revenue M BRL' datatype='real' name='[Calculation_0309987192791041]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_payment]) / 1000000' />
      </column>
      <column caption='Freight Ratio' datatype='real' name='[Calculation_0309987192872962]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_freight]) / SUM([total_items_price])' />
      </column>
      <column caption='Review Band' datatype='string' name='[Calculation_0309987193024515]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [review_score] &gt;= 4 THEN &quot;Positive (4-5)&quot; ELSEIF [review_score] &lt;= 2 THEN &quot;Negative (1-2)&quot; ELSE &quot;Neutral (3)&quot; END' />
      </column>
      <column caption='Late Flag' datatype='string' name='[Calculation_0309987193200644]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [is_on_time] = TRUE THEN &quot;On-Time&quot; ELSE &quot;Late&quot; END' />
      </column>
      <column caption='Repeat Purchase Rate' datatype='real' name='[Calculation_0309987198017545]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF {FIXED [customer_unique_id]: COUNT([order_id])} &gt; 1 THEN 1 ELSE 0 END) / COUNTD([customer_unique_id])' />
      </column>
      <column caption='Repeat Count' datatype='integer' name='[Calculation_1384622718906369]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [customer_unique_id]: COUNT([order_id])}' />
      </column>
      <column caption='Is Repeat' datatype='integer' name='[Calculation_1384622718971906]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1384622718906369] &gt; 1 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Repeat %' datatype='real' name='[Calculation_1384622719086595]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1384622718971906]) / COUNTD([customer_unique_id]) * 100' />
